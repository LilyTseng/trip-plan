rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 所有 rooms 文件：需要已登入（含匿名登入）才能讀寫
    match /rooms/{roomId} {
      allow read, write: if request.auth != null;
    }

    // 預設：拒絕所有其他存取
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
